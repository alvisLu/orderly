enum OrderStatus {
  pending
  processing
  cancelled
  done
}

enum OrderFinancialStatus {
  pending
  paid
  refunded
}

enum OrderFulfillmentStatus {
  pending
  fulfilled
  returned
}

model Order {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  note              String?
  total             Decimal                @db.Decimal(10, 2)
  source            String?                @db.VarChar(255)
  status            OrderStatus            @default(pending)
  financialStatus   OrderFinancialStatus   @default(pending)
  fulfillmentStatus OrderFulfillmentStatus @default(pending)
  isDining          Boolean                @default(false) @map("is_dining")
  lineItems         LineItem[]
  transactions      Json?                  @default("[]")
  discount          Decimal                @db.Decimal(10, 2)
  userPhone         String?                @map("user_phone") @db.VarChar(20)
  userNote          String?
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?              @map("deleted_at") @db.Timestamptz(6)

  @@map("orders")
}
